{
  "name": "noah-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm -w apps/noah-web-template run dev",
    "build": "npm -ws run build",
    "lint": "npm -ws run lint",
    "test": "npm -ws run test",
    "storybook": "npm -w packages/noah-ui run storybook",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.7"
  }
}